{
    "extends": "../tsconfig.base.json",
    "include": ["src", "vite.config.ts", "vitest.config.ts"],
    "compilerOptions": {
        "jsx": "react-jsx",
        "module": "ESNext",
        "lib": ["DOM", "DOM.Iterable", "ES2022"],
        "target": "ES2022",
        "types": ["vite/client", "node"],
        "resolveJsonModule": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "noEmit": true,
        "paths": {
            "@/*": ["./src/*"]
        }
    }
}
