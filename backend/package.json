{
    "name": "backend",
    "scripts": {
        "dev": "concurrently \"bun run redis-start\" \"bun run drizzle-studio\" \"bun run --hot src/index.ts\"",
        "drizzle-studio": "bunx drizzle-kit studio",
        "db:migrate": "bun run src/db/migrate.ts",
        "db:generate": "bunx drizzle-kit generate",
        "ingest": "bun run src/jobs/ingest.ts",
        "summaries:refresh": "bun run src/jobs/refresh-summaries.ts",
        "redis-start": "docker start my-movie-redis",
        "redis-stop": "docker stop my-movie-redis",
        "test": "bun test",
        "test:integration": "RUN_DB_INTEGRATION=1 bun test src/lib/conversation.integration.test.ts",
        "lint": "oxlint --type-aware src",
        "format": "prettier --write src",
        "format:check": "prettier --check src",
        "typecheck": "tsgo --noEmit"
    },
    "dependencies": {
        "@ai-sdk/openai": "^3.0.74",
        "@themovie/schemas": "workspace:*",
        "ai": "^6.0.209",
        "better-auth": "^1.4.9",
        "drizzle-orm": "^0.45.1",
        "hono": "^4.11.3",
        "zod": "^4.1.8"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@typescript/native-preview": "^7.0.0-dev.20260627.2",
        "concurrently": "^9.2.1",
        "drizzle-kit": "^0.31.8",
        "oxlint": "^1.71.0",
        "oxlint-tsgolint": "^0.23.0",
        "prettier": "^3.9.0",
        "typescript": "^5.7.0"
    }
}
