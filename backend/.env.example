# TheMovie — backend environment
# Copy to `.env` and fill in the blanks. NEVER commit the real `.env` (it's gitignored).

# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string. The DB must have the pgvector extension enabled
# (the agent's semantic search stores 1536-dim embeddings on the movies table).
# Default matches docker-compose.yml (host port 5433 — a host-native Postgres
# commonly owns 5432), so it works as-is with `docker compose up`.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/themovie

# ── Cache ─────────────────────────────────────────────────
# Bun's native Redis client (`import { redis } from "bun"`) reads this automatically.
REDIS_URL=redis://localhost:6379

# ── Auth (BetterAuth) ─────────────────────────────────────
# Strong random secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ── Frontend origin (CORS) ────────────────────────────────
# Used by the Hono CORS middleware to allow the TanStack Start app.
FRONTEND_URL=http://localhost:3001

# ── TMDB ──────────────────────────────────────────────────
# v4 read-access token (Bearer) — used by the TMDB service in src/lib/tmdb.ts.
TMDB_READ_ACCESS_API_KEY=
# v3 API key (optional/legacy).
TMDB_API_KEY=

# ── AI (OpenAI, via the Vercel AI SDK) ────────────────────
# Single AI vendor: powers the gpt-5 reasoning agent, the gpt-5-mini intent gate
# and review summaries, and text-embedding-3-small for pgvector semantic search.
OPENAI_API_KEY=

# ── Background jobs ───────────────────────────────────────
# In-process summary-refresh scheduler (src/jobs/scheduler.ts). It refreshes
# audience-review summaries + reception vectors on a timer, so it runs
# automatically wherever the backend is deployed — no external cron needed.
# Disabled when unset/0. Set the interval (hours) to enable; a Redis lock makes
# it safe behind a load balancer (only one instance runs per interval).
# In production, 24 (daily) is plenty — the tiers are day-scale.
SUMMARY_REFRESH_INTERVAL_HOURS=
# Also run once shortly after boot (handy right after a deploy). true | false.
SUMMARY_REFRESH_ON_BOOT=false
